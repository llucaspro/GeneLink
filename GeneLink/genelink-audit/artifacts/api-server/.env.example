# GeneLink — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# O arquivo .env NUNCA deve ser commitado no GitHub.

# ── Banco de dados PostgreSQL ──────────────────────────────────────────────────
# Formato: postgresql://usuario:senha@host:porta/nome_do_banco
# Exemplos de provedores gratuitos: Neon (neon.tech), Supabase, Railway
DATABASE_URL=postgresql://usuario:senha@host:5432/genelink

# ── Segredo da sessão Flask ────────────────────────────────────────────────────
# Qualquer string longa e aleatória. Gere com: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=troque_por_uma_string_aleatoria_longa

# ── Firebase (escolha UMA das opções abaixo) ──────────────────────────────────

# Opção A — Caminho para o arquivo JSON (recomendado para desenvolvimento local)
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

# Opção B — Conteúdo JSON como string (recomendado para produção/Render)
# Cole o conteúdo inteiro do arquivo JSON numa única linha:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"genelink-f2f02",...}

# ── Configurações opcionais ────────────────────────────────────────────────────
PORT=10000
BASE_URL=http://localhost:10000
